generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RequestStatus {
  open
  matched
  in_progress
  submitted
  completed
  cancelled
}

enum PlanVisibility {
  public
  private
}

enum MatchProposalStatus {
  pending
  accepted
  rejected
  cancelled
}

enum DirectProposalStatus {
  pending
  accepted
  rejected
  cancelled
}

enum PlanStatus {
  draft
  submitted
  completed
  approved
}

enum PlanType {
  request
  personal
}

enum PlanChangeSection {
  basic_info
  overview
  preparation
  hotels
  daily_timetable
  extras
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  bio           String?
  coinBalance   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  travellerRequests Request[]       @relation("TravellerRequests")
  plannerRequests   Request[]       @relation("PlannerRequests")
  plannerPlans      Plan[]          @relation("PlannerPlans")
  travellerPlans    Plan[]          @relation("TravellerPlans")
  proposals         MatchProposal[] @relation("PlannerProposals")

  travellerWrittenReviews PlannerReview[] @relation("TravellerWrittenReviews")
  plannerReceivedReviews  PlannerReview[] @relation("PlannerReceivedReviews")

  PlannerWrittenReports ReportTraveller[] @relation("PlannerWrittenReports")
  TravellerReceivedReorts  ReportTraveller[] @relation("TravellerReceivedReorts")

  planReviews             PlanReview[]    @relation("UserWrittenReviews")

  directProposalsReceived DirectProposal[] @relation("DirectProposalsReceived")
  directProposalsSent     DirectProposal[] @relation("DirectProposalsSent")

  sentRequestMessages   ChatMessages[] @relation("RequestMessageSender")
  plannerReviewSummary     PlannerReviewSummary?
}

model ReportTraveller {
  id              String   @id @default(cuid())

  requestId       String   @unique
  request         Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  travellerId     String
  traveller       User     @relation("PlannerWrittenReports", fields: [travellerId], references: [id], onDelete: Cascade)

  plannerId       String
  planner         User     @relation("TravellerReceivedReorts", fields: [plannerId], references: [id], onDelete: Cascade)

  content         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PlannerReviewSummary {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewCount     Int      @default(0)
  rating          Float    @default(0)
  planQuality     Float    @default(0)
  communication   Float    @default(0)
  timeliness      Float    @default(0)
  personalisation Float    @default(0)
  practicality    Float    @default(0)
  detailLevel     Float    @default(0)
  strengths       String   @default("")

  updatedAt       DateTime @updatedAt
}

model PlannerReview {
  id              String   @id @default(cuid())
  requestId       String   @unique
  request         Request  @relation(fields: [requestId], references: [id], onDelete: Cascade)

  travellerId     String
  traveller       User     @relation("TravellerWrittenReviews", fields: [travellerId], references: [id], onDelete: Cascade)

  plannerId       String
  planner         User     @relation("PlannerReceivedReviews", fields: [plannerId], references: [id], onDelete: Cascade)

  overallRating   Int
  planQuality     Int
  communication   Int
  timeliness      Int
  personalisation Int
  practicality    Int
  detailLevel     Int

  content         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DirectProposal {
  id           String               @id @default(cuid())
  plannerId    String
  travellerId  String

  title        String
  destination  String
  duration     String
  budget       String
  travelStyle  String
  interests    String[]
  extraNotes   String?

  status       DirectProposalStatus @default(pending)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  planner   User @relation("DirectProposalsReceived", fields: [plannerId], references: [id], onDelete: Cascade)
  traveller User @relation("DirectProposalsSent", fields: [travellerId], references: [id], onDelete: Cascade)

  @@index([plannerId])
  @@index([travellerId])
}

model Request {
  id               String        @id @default(cuid())
  travellerId      String
  plannerId        String?
  destination      String
  startDate        DateTime?
  endDate          DateTime?
  duration         String
  budget           String
  offerCost        Int           @default(0)
  travelStyle      String
  interests        String[]
  extraNotes       String?
  status           RequestStatus @default(open)
  coinTransferred  Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  completedAt      DateTime?    

  traveller User  @relation("TravellerRequests", fields: [travellerId], references: [id], onDelete: Cascade)
  planner   User? @relation("PlannerRequests", fields: [plannerId], references: [id], onDelete: SetNull)
  plannerReview PlannerReview?
  ReportTraveller ReportTraveller?

  plans     Plan[]
  proposals MatchProposal[]
  chatRoom     ChatRoom?

  @@index([travellerId])
  @@index([plannerId])
  @@index([status])
}

model Plan {
  id             String         @id @default(cuid())
  planType       PlanType       @default(personal)
  requestId      String?
  plannerId      String
  travellerId    String?
  title          String?
  destination    String?
  summary        String?
  price          Float?
  duration       String?
  visibility     PlanVisibility @default(private)
  status         PlanStatus     @default(draft)
  content        Json?
  previewContent Json?
  tags           String[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  submittedAt    DateTime?
  lastEditedAt   DateTime?
  lastEditNote   String?
  lastEditedSection String?

  request   Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  planner   User     @relation("PlannerPlans", fields: [plannerId], references: [id], onDelete: Cascade)
  traveller User?    @relation("TravellerPlans", fields: [travellerId], references: [id], onDelete: SetNull)

  planReviewSummary  PlanReviewSummary?
  planReviews        PlanReview[] @relation("PlanReceivedReviews")
  changeLogs         PlanChangeLog[]

  @@index([plannerId])
  @@index([travellerId])
  @@index([visibility])
  @@index([status])
}

model PlanChangeLog {
  id         String            @id @default(cuid())
  planId      String
  plan        Plan              @relation(fields: [planId], references: [id], onDelete: Cascade)

  section     String
  createdAt   DateTime          @default(now())

  @@index([planId, createdAt])
}

model PlanReviewSummary {
  id              String   @id @default(cuid())
  planId          String   @unique
  plan            Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  reviewCount     Int      @default(0)
  rating          Float    @default(0)
  planQuality     Float    @default(0)
  practicality    Float    @default(0)
  detailLevel     Float    @default(0)

  updatedAt       DateTime @updatedAt
}

model PlanReview {
  id              String   @id @default(cuid())

  userId       String
  user         User     @relation("UserWrittenReviews", fields: [userId], references: [id], onDelete: Cascade)
  planId       String
  plan         Plan     @relation("PlanReceivedReviews", fields: [planId], references: [id], onDelete: Cascade)

  overallRating   Int
  planQuality     Int
  practicality    Int
  detailLevel     Int

  content         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MatchProposal {
  id            String              @id @default(cuid())
  requestId      String
  plannerId      String
  message        String
  proposedPrice  Int?
  estimatedDays  Int?
  status         MatchProposalStatus @default(pending)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  planner User    @relation("PlannerProposals", fields: [plannerId], references: [id], onDelete: Cascade)

  @@unique([requestId, plannerId])
  @@index([requestId])
  @@index([plannerId])
  @@index([status])
}

model ChatRoom {
  id         String           @id @default(cuid())
  requestId   String           @unique
  request     Request          @relation(fields: [requestId], references: [id], onDelete: Cascade)

  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  messages   ChatMessages[]
}

model ChatMessages {
  id         String           @id @default(cuid())
  roomId      String
  room        ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  senderId    String?
  sender      User?           @relation("RequestMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  content     String
  isSystem    Boolean         @default(false)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([roomId, createdAt])
}

model ShopItems {
  id        String      @id @default(cuid())
  itemCode  String      @unique
  itemName  String
  coins     Int
  mainDescription String
  subDescription String

  prices ShopItemPrices[]
}

model ShopItemPrices {
  id      String    @id @default(cuid())

  shopItemId   String
  shopItem      ShopItems @relation(fields: [shopItemId], references: [id], onDelete: Cascade)

  countryCode  String
  price       Float
  isSale      Boolean   @default(false)
  salePrice   Float     @default(0)
} 